{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strict": true
  },
  "include": [
    "src",
    "index.js"
  ]
}
